generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite does not support enums. All enum-like fields are stored as
// plain String columns. Valid values are enforced at the application level.
//
// SubscriptionTier: FREE | PRO | TEAM | ENTERPRISE
// AuditStatus:      QUEUED | PROCESSING | CAPTURING | ANALYZING | MERGING | VERIFYING_FIXES | COMPLETED | FAILED
// Severity:         CRITICAL | SERIOUS | MODERATE | MINOR
// IssueCategory:    ACCESSIBILITY | UX_HEURISTIC | DESIGN_QUALITY | CUSTOM_RULE
// FixStatus:        PENDING | SUCCESS | FAILED | NOT_APPLICABLE
// IssueSource:      DETERMINISTIC | LLM | MERGED
// ScreenshotType:   ORIGINAL | PATCHED | HIGHLIGHTED
// MessageRole:      USER | ASSISTANT

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  passwordHash     String?
  githubAccessToken String?
  subscriptionTier String   @default("FREE")
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  projects      Project[]
  auditRuns     AuditRun[]          @relation("UserAuditRuns")
  remediations  GitHubRemediation[]
}

model Project {
  id        String   @id @default(uuid())
  userId    String
  name      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditRuns AuditRun[]
}

model AuditRun {
  id               String    @id @default(uuid())
  projectId        String
  userId           String
  status           String    @default("QUEUED")
  url              String
  inputType        String    @default("URL")
  uploadedImageUrl String?
  score            Int?
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User                @relation("UserAuditRuns", fields: [userId], references: [id], onDelete: Cascade)
  issues       Issue[]
  screenshots  Screenshot[]
  domSnapshot  DOMSnapshot?
  chatMessages ChatMessage[]
  remediations GitHubRemediation[]
}

model Issue {
  id                String   @id @default(uuid())
  auditRunId        String
  severity          String
  category          String
  elementSelector   String?
  description       String
  fixSuggestion     String?
  fixDiff           String?
  verifiedFixStatus String   @default("NOT_APPLICABLE")
  source            String
  confidence        String   @default("MEDIUM")
  actualValue       String?
  expectedValue     String?
  viewport          String?
  ruleId            String?
  sampleElements    String?
  pageUrl           String?
  createdAt         DateTime @default(now())

  auditRun    AuditRun     @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
  screenshots Screenshot[]
}

model Screenshot {
  id         String   @id @default(uuid())
  issueId    String?
  auditRunId String
  type       String
  url        String
  createdAt  DateTime @default(now())

  issue    Issue?   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  auditRun AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
}

model DOMSnapshot {
  id         String   @id @default(uuid())
  auditRunId String   @unique
  url        String
  createdAt  DateTime @default(now())

  auditRun AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id            String   @id @default(uuid())
  auditRunId    String
  role          String
  content       String
  citedIssueIds String   @default("[]")
  createdAt     DateTime @default(now())

  auditRun AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
}

// GitHubRemediation: PENDING | IN_PROGRESS | COMPLETED | FAILED
model GitHubRemediation {
  id               String   @id @default(uuid())
  auditRunId       String
  userId           String
  repoFullName     String
  baseBranch       String
  headBranch       String
  prUrl            String?
  prNumber         Int?
  status           String   @default("PENDING")
  selectedIssueIds String   @default("[]")
  includedIssueIds String   @default("[]")
  skippedIssueIds  String   @default("[]")
  createdAt        DateTime @default(now())

  auditRun AuditRun @relation(fields: [auditRunId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
