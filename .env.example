# ── Database (Prisma – SQLite) ────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── OpenAI (required for FastAPI audit engine + chat) ─────────
OPENAI_API_KEY="sk-..."

# ── NextAuth.js ───────────────────────────────────────────────
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="generate-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth providers (optional – credentials auth works without these) ──
GITHUB_ID=""
GITHUB_SECRET=""
GOOGLE_ID=""
GOOGLE_SECRET=""
FASTAPI_URL="http://localhost:8001"

# ── Smallest.ai Voice Summary (optional – enables "Listen to Summary") ───
SMALLEST_AI_API_KEY=""
SMALLEST_AI_VOICE_ID="meher"
SMALLEST_AI_MODEL="lightning_v3.1_pro"
