{
  "name": "ux-auditor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev",
    "dev:server": "server\\.venv\\Scripts\\python -m uvicorn server.main:app --port 8001",
    "dev:all": "start \"FastAPI\" cmd /c \"server\\.venv\\Scripts\\python -m uvicorn server.main:app --port 8001\" && next dev",
    "prebuild": "node -e \"fs=require('fs');fs.rmSync('.next',{recursive:true,force:true})\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "build:ci": "npm run typecheck && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:setup": "prisma generate && prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.12.1",
    "lucide-react": "^0.513.0",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.25",
    "openai": "^4.100.0",
    "playwright": "^1.52.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.3",
    "playwright-core": "^1.52.0",
    "postcss": "^8.5.0",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.3"
  }
}
